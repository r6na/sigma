<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Личный кабинет - Sigma</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Montserrat', sans-serif; color: #F5E6D3; background: #1A1814; min-height: 100vh; }
    .video-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; opacity: 0.25; filter: brightness(0.7) sepia(0.4); }
    .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(26,24,20,0.92), rgba(46,38,24,0.88), rgba(26,24,20,0.92)); z-index: -1; }
    .container { max-width: 1000px; margin: 0 auto; padding: 30px 20px; position: relative; z-index: 1; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px; }
    .header h1 { font-family: 'Bebas Neue', sans-serif; font-size: 42px; color: #D4A017; }
    .header a { background: transparent; color: #D4A017; text-decoration: none; padding: 10px 22px; border: 2px solid #D4A017; border-radius: 30px; font-weight: 600; font-size: 14px; }
    .header a:hover { background: #D4A017; color: #1A1814; }
    .card { background: rgba(196,184,154,0.06); backdrop-filter: blur(10px); border: 1px solid rgba(212,160,23,0.2); border-radius: 16px; padding: 25px; margin-bottom: 25px; }
    .card h2 { color: #D4A017; margin-bottom: 18px; font-weight: 600; }
    .order-item { background: rgba(26,24,20,0.4); border: 1px solid rgba(212,160,23,0.15); border-radius: 12px; padding: 18px 20px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
    .order-item .name { color: #E8D5B7; font-weight: 600; }
    .order-item .detail { color: #A8987A; font-size: 14px; }
    .order-item .price { color: #D4A017; font-weight: 600; }
    .status { padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .status-new { background: rgba(212,160,23,0.2); color: #D4A017; }
    .status-done { background: rgba(74,93,35,0.3); color: #A5C96A; }
    .empty { text-align: center; color: #7A6B5A; padding: 30px; }
  </style>
</head>
<body>
  <video autoplay muted loop playsinline class="video-bg"><source src="https://cdn.coverr.co/videos/coverr-sunflower-field-5244/1080p.mp4" type="video/mp4"></video>
  <div class="overlay"></div>
  <div class="container">
    <div class="header">
      <h1>Личный кабинет</h1>
      <div>
        <a href="/order">Оформить заказ</a>
        <a href="/logout" style="margin-left:10px;">Выйти</a>
      </div>
    </div>
    <div class="card">
      <h2>Добро пожаловать, <%= user.name %>!</h2>
    </div>
    <div class="card">
      <h2>История заказов</h2>
      <% if (orders.length === 0) { %>
        <div class="empty">У вас пока нет заказов. <a href="/order" style="color:#D4A017;">Оформить первый заказ</a></div>
      <% } else { %>
        <% orders.forEach(function(o) { %>
          <div class="order-item">
            <div>
              <div class="name"><%= o.product_name %></div>
              <div class="detail"><%= o.volume %> | <%= o.quantity %> шт. | <%= new Date(o.created_at).toLocaleDateString('ru-RU') %></div>
            </div>
            <div>
              <span class="status <%= o.status === 'Выполнен' ? 'status-done' : 'status-new' %>"><%= o.status %></span>
              <span class="price" style="margin-left:10px;"><%= o.total_price %> руб.</span>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
    <div style="text-align:center;"><a href="/" style="color:#D4A017;">На главную</a></div>
  </div>
</body>
</html>