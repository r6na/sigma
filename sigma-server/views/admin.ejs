<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Админ-панель - Sigma</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Montserrat', sans-serif; color: #F5E6D3; background: #1A1814; min-height: 100vh; }
    .video-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; opacity: 0.25; filter: brightness(0.7) sepia(0.4); }
    .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(26,24,20,0.92), rgba(46,38,24,0.88), rgba(26,24,20,0.92)); z-index: -1; }
    .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; position: relative; z-index: 1; }
    h1 { font-family: 'Bebas Neue', sans-serif; font-size: 42px; color: #D4A017; margin-bottom: 25px; }
    .header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 25px; }
    .header a { background: transparent; color: #D4A017; text-decoration: none; padding: 10px 22px; border: 2px solid #D4A017; border-radius: 30px; font-weight: 600; font-size: 14px; }
    .header a:hover { background: #D4A017; color: #1A1814; }
    .card { background: rgba(196,184,154,0.06); backdrop-filter: blur(10px); border: 1px solid rgba(212,160,23,0.2); border-radius: 16px; padding: 25px; margin-bottom: 25px; }
    .card h2 { color: #D4A017; margin-bottom: 18px; font-weight: 600; }
    table { width: 100%; border-collapse: collapse; }
    th { background: rgba(212,160,23,0.15); color: #D4A017; padding: 12px; text-align: left; font-size: 13px; }
    td { padding: 10px 12px; border-bottom: 1px solid rgba(212,160,23,0.1); font-size: 14px; color: #C4B89A; }
    form.inline { display: flex; gap: 8px; align-items: center; }
    form.inline select { padding: 6px 10px; border: 1px solid rgba(212,160,23,0.3); border-radius: 8px; background: rgba(26,24,20,0.6); color: #F5E6D3; font-size: 13px; }
    form.inline button { padding: 6px 14px; background: #D4A017; color: #1A1814; border: none; border-radius: 20px; font-weight: 600; font-size: 12px; cursor: pointer; }
    .add-form { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; }
    .add-form input { padding: 10px; border: 1px solid rgba(212,160,23,0.3); border-radius: 8px; background: rgba(26,24,20,0.6); color: #F5E6D3; font-size: 13px; font-family: 'Montserrat', sans-serif; }
    .add-form input:focus { outline: none; border-color: #D4A017; }
    .add-form button { padding: 10px; background: #D4A017; color: #1A1814; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; }
  </style>
</head>
<body>
  <video autoplay muted loop playsinline class="video-bg"><source src="https://cdn.coverr.co/videos/coverr-sunflower-field-5244/1080p.mp4" type="video/mp4"></video>
  <div class="overlay"></div>
  <div class="container">
    <div class="header">
      <h1>Админ-панель</h1>
      <div>
        <a href="/admin">Обновить</a>
        <a href="/logout">Выйти</a>
      </div>
    </div>

    <!-- Заказы -->
    <div class="card">
      <h2>Заказы (<%= orders.length %>)</h2>
      <div style="overflow-x:auto;">
        <table>
          <tr><th>ID</th><th>Клиент</th><th>Товар</th><th>Объём</th><th>Кол-во</th><th>Сумма</th><th>Статус</th><th>Действие</th></tr>
          <% orders.forEach(function(o) { %>
            <tr>
              <td><%= o.id %></td>
              <td><%= o.user_name %></td>
              <td><%= o.product_name %></td>
              <td><%= o.volume %></td>
              <td><%= o.quantity %></td>
              <td><%= o.total_price %> руб.</td>
              <td><%= o.status %></td>
              <td>
                <form method="POST" action="/admin/order/status" class="inline">
                  <input type="hidden" name="order_id" value="<%= o.id %>">
                  <select name="status">
                    <option <%= o.status === 'Новый' ? 'selected' : '' %>>Новый</option>
                    <option <%= o.status === 'В обработке' ? 'selected' : '' %>>В обработке</option>
                    <option <%= o.status === 'Выполнен' ? 'selected' : '' %>>Выполнен</option>
                  </select>
                  <button type="submit">OK</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </table>
      </div>
    </div>

    <!-- Добавить товар -->
    <div class="card">
      <h2>Добавить товар</h2>
      <form method="POST" action="/admin/product/add" class="add-form">
        <input name="name" placeholder="Название" required>
        <input name="category" placeholder="Категория">
        <input name="price" type="number" step="0.01" placeholder="Цена" required>
        <input name="volume_options" placeholder="Объёмы (через запятую)">
        <input name="description" placeholder="Описание">
        <input name="image_url" placeholder="URL картинки">
        <button type="submit">Добавить</button>
      </form>
    </div>

    <!-- Товары -->
    <div class="card">
      <h2>Товары (<%= products.length %>)</h2>
      <div style="overflow-x:auto;">
        <table>
          <tr><th>ID</th><th>Название</th><th>Категория</th><th>Цена</th><th>Объёмы</th></tr>
          <% products.forEach(function(p) { %>
            <tr>
              <td><%= p.id %></td>
              <td><%= p.name %></td>
              <td><%= p.category %></td>
              <td><%= p.price %> руб.</td>
              <td><%= p.volume_options %></td>
            </tr>
          <% }); %>
        </table>
      </div>
    </div>

    <!-- Пользователи -->
    <div class="card">
      <h2>Пользователи (<%= users.length %>)</h2>
      <div style="overflow-x:auto;">
        <table>
          <tr><th>ID</th><th>Имя</th><th>Email</th><th>Телефон</th><th>Дата регистрации</th></tr>
          <% users.forEach(function(u) { %>
            <tr>
              <td><%= u.id %></td>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td><%= u.phone || '-' %></td>
              <td><%= new Date(u.created_at).toLocaleDateString('ru-RU') %></td>
            </tr>
          <% }); %>
        </table>
      </div>
    </div>
  </div>
</body>
</html>