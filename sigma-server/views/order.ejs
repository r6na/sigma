<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Оформление заказа - Sigma</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Montserrat', sans-serif; color: #F5E6D3; background: #1A1814; min-height: 100vh; }
    .video-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; opacity: 0.25; filter: brightness(0.7) sepia(0.4); }
    .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(26,24,20,0.92), rgba(46,38,24,0.88), rgba(26,24,20,0.92)); z-index: -1; }
    .container { max-width: 900px; margin: 0 auto; padding: 30px 20px; position: relative; z-index: 1; }
    h1 { font-family: 'Bebas Neue', sans-serif; font-size: 42px; color: #D4A017; text-align: center; margin-bottom: 30px; }
    .card { background: rgba(196,184,154,0.06); backdrop-filter: blur(10px); border: 1px solid rgba(212,160,23,0.2); border-radius: 16px; padding: 30px; margin-bottom: 25px; }
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; margin-bottom: 20px; }
    .product-item { background: rgba(26,24,20,0.4); border: 1px solid rgba(212,160,23,0.15); border-radius: 12px; padding: 18px; cursor: pointer; transition: all 0.3s; }
    .product-item:hover, .product-item.selected { border-color: #D4A017; background: rgba(212,160,23,0.08); }
    .product-item h3 { color: #E8D5B7; font-size: 16px; margin-bottom: 5px; }
    .product-item .cat { color: #A8987A; font-size: 12px; }
    .product-item .price { color: #D4A017; font-weight: 600; font-size: 18px; }
    .product-item .vol { color: #7A6B5A; font-size: 13px; margin-top: 5px; }
    form { display: grid; gap: 15px; max-width: 500px; }
    form select, form input { padding: 12px; border: 1px solid rgba(212,160,23,0.3); border-radius: 10px; background: rgba(26,24,20,0.6); color: #F5E6D3; font-size: 15px; font-family: 'Montserrat', sans-serif; }
    form select:focus, form input:focus { outline: none; border-color: #D4A017; }
    form button { padding: 14px; background: #D4A017; color: #1A1814; border: none; border-radius: 30px; font-weight: 700; font-size: 16px; cursor: pointer; font-family: 'Montserrat', sans-serif; }
    form button:hover { background: #E5B52D; }
    .back-link { display: block; text-align: center; margin-top: 20px; color: #D4A017; text-decoration: none; }
  </style>
</head>
<body>
  <video autoplay muted loop playsinline class="video-bg"><source src="https://cdn.coverr.co/videos/coverr-sunflower-field-5244/1080p.mp4" type="video/mp4"></video>
  <div class="overlay"></div>
  <div class="container">
    <h1>Оформление заказа</h1>
    <div class="card">
      <h2 style="color:#D4A017; margin-bottom:15px;">Выберите продукт</h2>
      <div class="product-grid" id="productGrid">
        <% products.forEach(function(p) { %>
          <div class="product-item" data-id="<%= p.id %>" data-price="<%= p.price %>" data-name="<%= p.name %>" data-vol="<%= p.volume_options %>" onclick="selectProduct(this)">
            <h3><%= p.name %></h3>
            <div class="cat"><%= p.category %></div>
            <div class="price"><%= p.price %> руб.</div>
            <div class="vol"><%= p.volume_options %></div>
          </div>
        <% }); %>
      </div>
      <form method="POST" action="/order" id="orderForm">
        <input type="hidden" name="product_id" id="productId" required>
        <label style="color:#C4B89A;">Выбранный товар: <strong id="selectedName" style="color:#D4A017;">-</strong></label>
        <select name="volume" required>
          <option value="">Выберите объём</option>
        </select>
        <input type="number" name="quantity" placeholder="Количество" min="1" value="1" required>
        <button type="submit">Оформить заказ</button>
      </form>
    </div>
    <a href="/dashboard" class="back-link">В личный кабинет</a>
  </div>
  <script>
    let selectedId = null;
    function selectProduct(el) {
      document.querySelectorAll('.product-item').forEach(i => i.classList.remove('selected'));
      el.classList.add('selected');
      selectedId = el.dataset.id;
      document.getElementById('productId').value = selectedId;
      document.getElementById('selectedName').textContent = el.dataset.name;
      const volSelect = document.querySelector('select[name="volume"]');
      volSelect.innerHTML = '<option value="">Выберите объём</option>';
      const options = el.dataset.vol.split(',').map(v => v.trim());
      options.forEach(v => { const o = document.createElement('option'); o.value = v; o.textContent = v; volSelect.appendChild(o); });
    }
  </script>
</body>
</html>